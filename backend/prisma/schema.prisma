generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  PROFESSOR
  ALUNO
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  email     String   @unique
  password  String
  role      UserRole
  createdAt DateTime @default(now())
  courses   Course[]
}

model Course {
  id          String   @id @default(uuid()) @db.Uuid
  title       String
  description String
  createdBy   String   @db.Uuid
  createdAt   DateTime @default(now())
  creator     User     @relation(fields: [createdBy], references: [id])
}
